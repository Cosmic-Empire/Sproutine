# VAPID keys — generate once via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
# NEXT_PUBLIC copy of VAPID_PUBLIC_KEY — same value, exposed to the browser for pushManager.subscribe()
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Cron — any random string, used to verify Vercel Cron requests hit /api/notify
CRON_SECRET=generate-a-random-string-here
